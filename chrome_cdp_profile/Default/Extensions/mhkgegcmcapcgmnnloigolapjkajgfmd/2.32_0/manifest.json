{
   "action": {
      "default_icon": "bmp128.png",
      "default_title": "Browser Security"
   },
   "background": {
      "service_worker": "js/service-worker.js"
   },
   "content_scripts": [ {
      "js": [ "js/contentScript.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start"
   }, {
      "all_frames": true,
      "js": [ "js/uploadmanager.js" ],
      "match_origin_as_fallback": true,
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   } ],
   "description": "Manage Google Chrome using Browser Security Plus extension",
   "homepage_url": "https://www.manageengine.com/browser-security/",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "bmp128.png",
      "16": "bmp16.png",
      "48": "bmp48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Browser Security Plus",
   "permissions": [ "management", "webRequest", "nativeMessaging", "privacy", "contentSettings", "downloads", "scripting", "tabs" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.32",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "data-extractor.js", "download_restriction.html" ]
   } ]
}
